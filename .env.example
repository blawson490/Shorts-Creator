# Postgres
POSTGRES_DB=shorts
POSTGRES_USER=shorts_user
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_PORT=5432

# Supabase local services
SUPABASE_SITE_URL=http://localhost:3000
SUPABASE_URI_ALLOW_LIST=http://localhost:3000
SUPABASE_JWT_SECRET=super-long-development-jwt-secret-at-least-32-chars
SUPABASE_JWT_EXP=3600
SUPABASE_DISABLE_SIGNUP=false
SUPABASE_DB_SCHEMA=public
SUPABASE_DB_ANON_ROLE=anon
SUPABASE_AUTH_PORT=9999
SUPABASE_REST_PORT=3000
SUPABASE_AUTH_URL=http://localhost:9999
SUPABASE_REST_URL=http://localhost:3000

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET=shorts-assets
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_CONSOLE_URL=http://localhost:9001
